{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AudioSnip",
  "identifier": "ch.avoni.audio-snip",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AudioSnip",
        "width": 860,
        "height": 700
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' http://127.0.0.1:*; img-src 'self'; media-src 'self' blob: http://127.0.0.1:*; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
